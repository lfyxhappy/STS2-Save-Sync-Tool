<Window x:Class="Sts2SaveSyncTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:Sts2SaveSyncTool.Models"
        mc:Ignorable="d"
        Title="STS2 官方档 / Modded 档进度同步 made by 良风"
        Width="1460"
        Height="980"
        MinWidth="1240"
        MinHeight="820"
        Background="#0B1220"
        Loaded="Window_Loaded">
  <Window.Resources>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="#14233B" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style x:Key="InnerPanelStyle" TargetType="Border">
      <Setter Property="Background" Value="#0F1A2D" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#E5EEF9" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#95A8C7" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,8,0,2" />
    </Style>
    <Style x:Key="FieldValueStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#2F6FED" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Padding" Value="16,8" />
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="10">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.45" />
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
      <Setter Property="Background" Value="#2C8A6D" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style x:Key="InputBoxStyle" TargetType="TextBox">
      <Setter Property="Background" Value="#0F1A2D" />
      <Setter Property="Foreground" Value="#F4F8FF" />
      <Setter Property="BorderBrush" Value="#284263" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,7" />
    </Style>
  </Window.Resources>

  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Style="{StaticResource CardStyle}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock Text="STS2 官方档 / Modded 档进度同步 made by 良风"
                       Foreground="#F7FAFF"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Text="手动查看差异，再决定同步方向。工具不会自动判断哪边更新。"
                       Foreground="#9FB4D5"
                       FontSize="13"
                       Margin="0,6,0,0" />
          </StackPanel>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,12,0">
            <TextBlock Text="Steam 账号"
                       Foreground="#D8E3F3"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <ComboBox x:Name="AccountSelector"
                      Width="260"
                      ItemsSource="{Binding SteamAccounts}"
                      SelectedItem="{Binding SelectedAccount}"
                      DisplayMemberPath="DisplayName"
                      SelectionChanged="AccountSelector_SelectionChanged" />
          </StackPanel>

          <Button Grid.Column="2"
                  Content="刷新"
                  Click="RefreshButton_Click"
                  Style="{StaticResource SecondaryButtonStyle}"
                  VerticalAlignment="Center" />
        </Grid>

        <TextBlock Grid.Row="1"
                   Text="{Binding SafetyTip}"
                   Foreground="#F5C76E"
                   FontSize="13"
                   Margin="0,16,0,0"
                   TextWrapping="Wrap" />

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
          <TextBlock Text="高级路径（可选）"
                     Foreground="#D8E3F3"
                     FontSize="13"
                     FontWeight="SemiBold" />

          <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Steam 根目录覆盖"
                       Foreground="#D8E3F3"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBox Grid.Column="1"
                     Style="{StaticResource InputBoxStyle}"
                     Margin="0,0,12,0"
                     Text="{Binding SteamRootOverride, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2"
                    Content="应用路径"
                    Click="ApplySteamRootOverride_Click"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="0,0,10,0" />
            <Button Grid.Column="3"
                    Content="清空覆盖"
                    Click="ClearSteamRootOverride_Click"
                    Style="{StaticResource SecondaryButtonStyle}" />
          </Grid>

          <TextBlock Text="{Binding EffectiveSteamRootText}"
                     Foreground="#9FB4D5"
                     FontSize="12"
                     Margin="0,10,0,0"
                     TextWrapping="Wrap" />
          <TextBlock Text="{Binding CacheEnvironmentText}"
                     Foreground="#9FB4D5"
                     FontSize="12"
                     Margin="0,4,0,0"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" Margin="0,18,0,18" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding ProfilePairs}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="{x:Type models:ProfilePairState}">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                  <TextBlock Text="{Binding ProfileTitle}"
                             Foreground="#F6FAFF"
                             FontSize="20"
                             FontWeight="Bold"
                             DockPanel.Dock="Left" />
                  <Border DockPanel.Dock="Right"
                          Background="#204B95"
                          CornerRadius="999"
                          Padding="10,3"
                          Visibility="{Binding IsCurrentProfile, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="当前"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="SemiBold" />
                  </Border>
                </DockPanel>

                <Grid Grid.Row="1" Margin="0,16,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.3*" />
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="2.3*" />
                  </Grid.ColumnDefinitions>

                  <Border Grid.Column="0" Style="{StaticResource InnerPanelStyle}">
                    <StackPanel>
                      <TextBlock Text="普通档" Style="{StaticResource SectionTitleStyle}" />

                      <TextBlock Text="文件状态" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.FileStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="修改时间" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.LastWriteTimeText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="本地 backup" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.BackupStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="Steam 缓存摘要" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.CacheSnapshot.SummaryText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="缓存文件" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.CacheSnapshot.CacheFileStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="缓存条目" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.CacheSnapshot.RemoteCacheEntryStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="总时长" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.TotalPlaytimeText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="爬楼层数" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.FloorsClimbedText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="总解锁" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.TotalUnlocksText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="多人难度偏好" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.PreferredMultiplayerAscensionText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="角色难度摘要" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding NormalSnapshot.CharacterSummaryText}"
                                 Style="{StaticResource FieldValueStyle}"
                                 FontFamily="Consolas" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="1" Style="{StaticResource InnerPanelStyle}" Margin="14,0">
                    <StackPanel>
                      <TextBlock Text="差异摘要" Style="{StaticResource SectionTitleStyle}" />

                      <TextBlock Text="比较结果" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding DiffSummary.SummaryText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="全局字段对比" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding DiffSummary.GlobalSummaryText}"
                                 Style="{StaticResource FieldValueStyle}"
                                 FontFamily="Consolas" />

                      <TextBlock Text="缓存一致性" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding DiffSummary.CacheConsistencyText}"
                                 Style="{StaticResource FieldValueStyle}"
                                 FontFamily="Consolas" />

                      <TextBlock Text="角色难度差异" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding DiffSummary.CharacterDifferenceText}"
                                 Style="{StaticResource FieldValueStyle}"
                                 FontFamily="Consolas" />
                    </StackPanel>
                  </Border>

                  <Border Grid.Column="2" Style="{StaticResource InnerPanelStyle}">
                    <StackPanel>
                      <TextBlock Text="Modded 档" Style="{StaticResource SectionTitleStyle}" />

                      <TextBlock Text="文件状态" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.FileStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="修改时间" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.LastWriteTimeText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="本地 backup" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.BackupStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="Steam 缓存摘要" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.CacheSnapshot.SummaryText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="缓存文件" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.CacheSnapshot.CacheFileStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="缓存条目" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.CacheSnapshot.RemoteCacheEntryStateText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="总时长" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.TotalPlaytimeText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="爬楼层数" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.FloorsClimbedText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="总解锁" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.TotalUnlocksText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="多人难度偏好" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.PreferredMultiplayerAscensionText}" Style="{StaticResource FieldValueStyle}" />

                      <TextBlock Text="角色难度摘要" Style="{StaticResource FieldLabelStyle}" />
                      <TextBlock Text="{Binding ModdedSnapshot.CharacterSummaryText}"
                                 Style="{StaticResource FieldValueStyle}"
                                 FontFamily="Consolas" />
                    </StackPanel>
                  </Border>
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                  <Button Content="同步到 Modded"
                          Click="SyncToModded_Click"
                          IsEnabled="{Binding CanSyncToModded}"
                          Style="{StaticResource PrimaryButtonStyle}" />
                  <Button Content="同步到普通档"
                          Click="SyncToNormal_Click"
                          IsEnabled="{Binding CanSyncToNormal}"
                          Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <Border Grid.Row="2" Style="{StaticResource CardStyle}">
      <TextBlock Text="{Binding StatusMessage}"
                 Foreground="{Binding StatusBrush}"
                 FontSize="13"
                 TextWrapping="Wrap" />
    </Border>
  </Grid>
</Window>
